# ═══════════════════════════════════════════════════════════════
# БАЗОВЫЙ ОБРАЗ: используем официальный Python 3.11 slim
# Slim-версия весит ~150 МБ вместо ~900 МБ у полной версии
# ═══════════════════════════════════════════════════════════════
FROM python:3.11-slim

# ═══════════════════════════════════════════════════════════════
# МЕТАДАННЫЕ: для документации и отладки
# ═══════════════════════════════════════════════════════════════
LABEL maintainer="dainarius@example.com"
LABEL description="MLOps Journey: Churn Prediction Pipeline"
LABEL version="1.0"

# ═══════════════════════════════════════════════════════════════
# ПЕРЕМЕННЫЕ ОКРУЖЕНИЯ
# PYTHONUNBUFFERED=1 — отключает буферизацию вывода (логи видны сразу)
# PYTHONDONTWRITEBYTECODE=1 — не создаёт .pyc файлы (экономия места)
# ═══════════════════════════════════════════════════════════════
ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

# ═══════════════════════════════════════════════════════════════
# РАБОЧАЯ ДИРЕКТОРИЯ: все команды будут выполняться здесь
# ═══════════════════════════════════════════════════════════════
WORKDIR /app

# ═══════════════════════════════════════════════════════════════
# СИСТЕМНЫЕ ЗАВИСИМОСТИ: устанавливаем только необходимое
# build-essential — для компиляции некоторых Python-пакетов
# git — если нужны зависимости из GitHub
# ═══════════════════════════════════════════════════════════════
RUN apt-get update && apt-get install -y \
    build-essential \
    git \
    && rm -rf /var/lib/apt/lists/*

# ═══════════════════════════════════════════════════════════════
# УСТАНОВКА PYTHON-ЗАВИСИМОСТЕЙ
# Сначала копируем только requirements.txt — это позволяет Docker
# кэшировать слой и не переустанавливать зависимости при каждом
# изменении кода (ускоряет сборку в 10 раз!)
# ═══════════════════════════════════════════════════════════════
COPY requirements.txt .

RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir -r requirements.txt

# ═══════════════════════════════════════════════════════════════
# КОПИРУЕМ КОД: только после установки зависимостей
# Это оптимизация: если изменили только код, зависимости не переустанавливаются
# ═══════════════════════════════════════════════════════════════
COPY src/ ./src/
COPY Makefile .

# ═══════════════════════════════════════════════════════════════
# СОЗДАЁМ ДИРЕКТОРИИ: для данных и артефактов
# Они будут монтироваться через volumes при запуске
# ═══════════════════════════════════════════════════════════════
RUN mkdir -p /app/data/raw /app/artifacts /app/models

# ═══════════════════════════════════════════════════════════════
# ПОЛЬЗОВАТЕЛЬ: для безопасности не запускаем от root
# Создаём непривилегированного пользователя
# ═══════════════════════════════════════════════════════════════
RUN useradd -m -u 1000 mlops && \
    chown -R mlops:mlops /app
USER mlops

# ═══════════════════════════════════════════════════════════════
# КОМАНДА ПО УМОЛЧАНИЮ: что делать при запуске контейнера
# Можно переопределить при запуске: docker run <image> python src/predict.py
# ═══════════════════════════════════════════════════════════════
CMD ["python", "src/train.py"]
